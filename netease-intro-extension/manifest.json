{
  "manifest_version": 3,
  "name": "歌单电台",
  "version": "2.0",
  "description": "把你的歌单变成一档私人音乐电台",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://music.163.com/*",
    "*://*.y.qq.com/*",
    "*://y.qq.com/*",
    "https://dashscope.aliyuncs.com/*",
    "https://api.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "歌单电台",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://music.163.com/*",
        "*://*.y.qq.com/*",
        "*://y.qq.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://music.163.com/*"],
      "js": ["adapters/netease.js", "intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.y.qq.com/*", "*://y.qq.com/*"],
      "js": ["adapters/qq.js", "intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
